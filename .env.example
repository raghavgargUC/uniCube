# ─── Cube.js Core ──────────────────────────────────────────
CUBEJS_API_SECRET=your-shared-jwt-secret-here
CUBEJS_DEV_MODE=true
# Set to true on the refresh worker instance
CUBEJS_REFRESH_WORKER=false
CUBEJS_DB_TYPE=mysql

# ─── MySQL Credentials (per-cloud hosts) ──────────────────
DB_USER=uniware
DB_PASS=changeme

# ─── Uniware Cloud Hosts (JSON) ──────────────────────────
# Format: { "cloud_key": { "host": "...", "database": "...", "pool": { "min": 1, "max": 5 } } }
UNIWARE_HOSTS={"ecloud3":{"host":"db-slave.ecloud3-in.unicommerce.infra","database":"uniware","pool":{"min":1,"max":5}}}

# ─── Shared Warehouse (MySQL) ────────────────────────────
WAREHOUSE_HOST=db.reco-stg-in.unicommerce.infra
WAREHOUSE_PORT=3306
WAREHOUSE_DB=uniware
WAREHOUSE_USER=root
WAREHOUSE_PASS=changeme
WAREHOUSE_POOL_MAX=4

# ─── MongoDB (tenant registry) ─────────────────────────────
MONGO_URI=mongodb://mongo.recostg-in.unicommerce.infra:27017
MONGO_DB=unicube
# Cache TTL in seconds (default 300 = 5 min)
MONGO_CACHE_TTL=300

# ─── Server ───────────────────────────────────────────────
PORT=4000
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
