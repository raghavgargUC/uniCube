# ─── Cube.js Core ──────────────────────────────────────────
CUBEJS_API_SECRET=your-shared-jwt-secret-here
CUBEJS_DEV_MODE=true
# Set to true on the refresh worker instance
CUBEJS_REFRESH_WORKER=false

# ─── MySQL Credentials (per-cloud hosts) ──────────────────
DB_USER=uniware
DB_PASS=changeme

# ─── Shared Warehouse (MySQL) ────────────────────────────
WAREHOUSE_HOST=db.reco-stg-in.unicommerce.infra
WAREHOUSE_PORT=3306
WAREHOUSE_DB=uniware
WAREHOUSE_USER=root
WAREHOUSE_PASS=changeme
WAREHOUSE_POOL_MAX=4

# ─── Server ───────────────────────────────────────────────
PORT=4000
